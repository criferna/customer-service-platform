{
  "__comment": "Dashboard de Grafana para el lab de microservicios. Importar en Grafana > Dashboards > Import.",
  "dashboard": {
    "title": "Customer Service Platform - Microservices",
    "tags": ["microservices", "customer-platform"],
    "timezone": "browser",
    "panels": [
      {
        "title": "HTTP Requests per Service",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Request Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Service Health Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "up{job=~\".*microservice.*\"}",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Container Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{name=~\"cs-.*\"} / 1024 / 1024",
            "legendFormat": "{{name}} (MB)"
          }
        ]
      }
    ]
  }
}
